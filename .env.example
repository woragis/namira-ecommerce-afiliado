# Supabase Postgres — Dashboard → Connect → ORMs → Prisma
# Transaction pooler (6543) = app / Vercel (DATABASE_URL)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Session pooler (5432 no host pooler) = db push / seed (DIRECT_URL)
# NÃO use db.[ref].supabase.co:5432 se der P1001 (IPv6/rede)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require"

# Local com Docker (docker compose up -d):
# DATABASE_URL="postgresql://namira:namira@localhost:5433/namira"
# DIRECT_URL="postgresql://namira:namira@localhost:5433/namira"

# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Buckets: store-logos, product-images (criar no Storage com leitura pública)
# product-images aceita imagens (PNG/JPG/WebP/SVG) e vídeos (MP4/WebM)
NEXT_PUBLIC_BUCKET_STORE_LOGOS="store-logos"
NEXT_PUBLIC_BUCKET_PRODUCT_IMAGES="product-images"

# Admin (recomendado em produção — protege /admin)
ADMIN_SECRET="dev-admin-secret"

# Métricas no admin (gráficos, funil, tabelas). Desligado por padrão — deixa o painel mais rápido.
# ADMIN_METRICS_ENABLED="true"

# SEO (sitemap e robots)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
